{"ast":null,"code":"import { Editor, Toolbar } from '@wangeditor/editor-for-vue';\nimport axios from 'axios';\nexport default {\n  components: {\n    Editor,\n    Toolbar\n  },\n  props: {\n    modelValue: {\n      type: String,\n      default: ''\n    },\n    mode: {\n      type: String,\n      default: 'default' // 'default' 或 'simple'\n    }\n  },\n  emits: ['update:modelValue'],\n  data() {\n    return {\n      editorRef: null,\n      valueHtml: this.modelValue,\n      toolbarConfig: {},\n      editorConfig: {\n        placeholder: '请输入内容...',\n        MENU_CONF: {\n          uploadImage: {\n            fieldName: 'file',\n            maxFileSize: 10 * 1024 * 1024,\n            // 10MB\n            maxNumberOfFiles: 10,\n            allowedFileTypes: ['image/jpeg', 'image/png', 'image/gif', 'image/webp'],\n            customUpload: async (files, insertFn) => {\n              for (let file of files) {\n                try {\n                  const formData = new FormData();\n                  formData.append('file', file);\n                  const response = await axios.post('/api/v1/files/upload', formData, {\n                    headers: {\n                      'Content-Type': 'multipart/form-data'\n                    }\n                  });\n                  if (response.data.success) {\n                    insertFn(response.data.data.url);\n                  } else {\n                    console.error('上传失败:', response.data.message);\n                    this.$message.error('图片上传失败');\n                  }\n                } catch (error) {\n                  console.error('上传错误:', error);\n                  this.$message.error('图片上传出错');\n                }\n              }\n            }\n          }\n        }\n      }\n    };\n  },\n  watch: {\n    modelValue(newVal) {\n      if (newVal !== this.valueHtml) {\n        this.valueHtml = newVal;\n      }\n    },\n    valueHtml(newVal) {\n      if (newVal !== this.modelValue) {\n        this.$emit('update:modelValue', newVal);\n      }\n    }\n  },\n  methods: {\n    handleCreated(editor) {\n      this.editorRef = editor;\n    },\n    handleChange(editor) {\n      this.valueHtml = editor.getHtml();\n    },\n    destroy() {\n      if (this.editorRef == null) return;\n      this.editorRef.destroy();\n      this.editorRef = null;\n    }\n  },\n  beforeUnmount() {\n    this.destroy();\n  }\n};","map":{"version":3,"names":["Editor","Toolbar","axios","components","props","modelValue","type","String","default","mode","emits","data","editorRef","valueHtml","toolbarConfig","editorConfig","placeholder","MENU_CONF","uploadImage","fieldName","maxFileSize","maxNumberOfFiles","allowedFileTypes","customUpload","files","insertFn","file","formData","FormData","append","response","post","headers","success","url","console","error","message","$message","watch","newVal","$emit","methods","handleCreated","editor","handleChange","getHtml","destroy","beforeUnmount"],"sources":["/app/portal-system/portal-admin/src/components/WangEditor.vue"],"sourcesContent":["<template>\n  <div style=\"border: 1px solid #ccc\">\n    <Toolbar\n      style=\"border-bottom: 1px solid #ccc\"\n      :editor=\"editorRef\"\n      :default-config=\"toolbarConfig\"\n      :mode=\"mode\"\n    />\n    <Editor\n      style=\"height: 500px; overflow-y: hidden;\"\n      v-model=\"valueHtml\"\n      :default-config=\"editorConfig\"\n      :mode=\"mode\"\n      @on-created=\"handleCreated\"\n      @on-change=\"handleChange\"\n    />\n  </div>\n</template>\n\n<script>\nimport { Editor, Toolbar } from '@wangeditor/editor-for-vue'\nimport axios from 'axios'\n\nexport default {\n  components: { Editor, Toolbar },\n  props: {\n    modelValue: {\n      type: String,\n      default: ''\n    },\n    mode: {\n      type: String,\n      default: 'default' // 'default' 或 'simple'\n    }\n  },\n  emits: ['update:modelValue'],\n  data() {\n    return {\n      editorRef: null,\n      valueHtml: this.modelValue,\n      toolbarConfig: {},\n      editorConfig: {\n        placeholder: '请输入内容...',\n        MENU_CONF: {\n          uploadImage: {\n            fieldName: 'file',\n            maxFileSize: 10 * 1024 * 1024, // 10MB\n            maxNumberOfFiles: 10,\n            allowedFileTypes: ['image/jpeg', 'image/png', 'image/gif', 'image/webp'],\n            customUpload: async (files, insertFn) => {\n              for (let file of files) {\n                try {\n                  const formData = new FormData()\n                  formData.append('file', file)\n                  \n                  const response = await axios.post('/api/v1/files/upload', formData, {\n                    headers: {\n                      'Content-Type': 'multipart/form-data'\n                    }\n                  })\n                  \n                  if (response.data.success) {\n                    insertFn(response.data.data.url)\n                  } else {\n                    console.error('上传失败:', response.data.message)\n                    this.$message.error('图片上传失败')\n                  }\n                } catch (error) {\n                  console.error('上传错误:', error)\n                  this.$message.error('图片上传出错')\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  },\n  watch: {\n    modelValue(newVal) {\n      if (newVal !== this.valueHtml) {\n        this.valueHtml = newVal\n      }\n    },\n    valueHtml(newVal) {\n      if (newVal !== this.modelValue) {\n        this.$emit('update:modelValue', newVal)\n      }\n    }\n  },\n  methods: {\n    handleCreated(editor) {\n      this.editorRef = editor\n    },\n    handleChange(editor) {\n      this.valueHtml = editor.getHtml()\n    },\n    destroy() {\n      if (this.editorRef == null) return\n      this.editorRef.destroy()\n      this.editorRef = null\n    }\n  },\n  beforeUnmount() {\n    this.destroy()\n  }\n}\n</script>\n\n<style src=\"@wangeditor/editor/dist/css/style.css\"></style>"],"mappings":"AAoBA,SAASA,MAAM,EAAEC,OAAM,QAAS,4BAA2B;AAC3D,OAAOC,KAAI,MAAO,OAAM;AAExB,eAAe;EACbC,UAAU,EAAE;IAAEH,MAAM;IAAEC;EAAQ,CAAC;EAC/BG,KAAK,EAAE;IACLC,UAAU,EAAE;MACVC,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE;IACX,CAAC;IACDC,IAAI,EAAE;MACJH,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE,SAAQ,CAAE;IACrB;EACF,CAAC;EACDE,KAAK,EAAE,CAAC,mBAAmB,CAAC;EAC5BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,IAAI;MACfC,SAAS,EAAE,IAAI,CAACR,UAAU;MAC1BS,aAAa,EAAE,CAAC,CAAC;MACjBC,YAAY,EAAE;QACZC,WAAW,EAAE,UAAU;QACvBC,SAAS,EAAE;UACTC,WAAW,EAAE;YACXC,SAAS,EAAE,MAAM;YACjBC,WAAW,EAAE,EAAC,GAAI,IAAG,GAAI,IAAI;YAAE;YAC/BC,gBAAgB,EAAE,EAAE;YACpBC,gBAAgB,EAAE,CAAC,YAAY,EAAE,WAAW,EAAE,WAAW,EAAE,YAAY,CAAC;YACxEC,YAAY,EAAE,MAAAA,CAAOC,KAAK,EAAEC,QAAQ,KAAK;cACvC,KAAK,IAAIC,IAAG,IAAKF,KAAK,EAAE;gBACtB,IAAI;kBACF,MAAMG,QAAO,GAAI,IAAIC,QAAQ,CAAC;kBAC9BD,QAAQ,CAACE,MAAM,CAAC,MAAM,EAAEH,IAAI;kBAE5B,MAAMI,QAAO,GAAI,MAAM5B,KAAK,CAAC6B,IAAI,CAAC,sBAAsB,EAAEJ,QAAQ,EAAE;oBAClEK,OAAO,EAAE;sBACP,cAAc,EAAE;oBAClB;kBACF,CAAC;kBAED,IAAIF,QAAQ,CAACnB,IAAI,CAACsB,OAAO,EAAE;oBACzBR,QAAQ,CAACK,QAAQ,CAACnB,IAAI,CAACA,IAAI,CAACuB,GAAG;kBACjC,OAAO;oBACLC,OAAO,CAACC,KAAK,CAAC,OAAO,EAAEN,QAAQ,CAACnB,IAAI,CAAC0B,OAAO;oBAC5C,IAAI,CAACC,QAAQ,CAACF,KAAK,CAAC,QAAQ;kBAC9B;gBACF,EAAE,OAAOA,KAAK,EAAE;kBACdD,OAAO,CAACC,KAAK,CAAC,OAAO,EAAEA,KAAK;kBAC5B,IAAI,CAACE,QAAQ,CAACF,KAAK,CAAC,QAAQ;gBAC9B;cACF;YACF;UACF;QACF;MACF;IACF;EACF,CAAC;EACDG,KAAK,EAAE;IACLlC,UAAUA,CAACmC,MAAM,EAAE;MACjB,IAAIA,MAAK,KAAM,IAAI,CAAC3B,SAAS,EAAE;QAC7B,IAAI,CAACA,SAAQ,GAAI2B,MAAK;MACxB;IACF,CAAC;IACD3B,SAASA,CAAC2B,MAAM,EAAE;MAChB,IAAIA,MAAK,KAAM,IAAI,CAACnC,UAAU,EAAE;QAC9B,IAAI,CAACoC,KAAK,CAAC,mBAAmB,EAAED,MAAM;MACxC;IACF;EACF,CAAC;EACDE,OAAO,EAAE;IACPC,aAAaA,CAACC,MAAM,EAAE;MACpB,IAAI,CAAChC,SAAQ,GAAIgC,MAAK;IACxB,CAAC;IACDC,YAAYA,CAACD,MAAM,EAAE;MACnB,IAAI,CAAC/B,SAAQ,GAAI+B,MAAM,CAACE,OAAO,CAAC;IAClC,CAAC;IACDC,OAAOA,CAAA,EAAG;MACR,IAAI,IAAI,CAACnC,SAAQ,IAAK,IAAI,EAAE;MAC5B,IAAI,CAACA,SAAS,CAACmC,OAAO,CAAC;MACvB,IAAI,CAACnC,SAAQ,GAAI,IAAG;IACtB;EACF,CAAC;EACDoC,aAAaA,CAAA,EAAG;IACd,IAA