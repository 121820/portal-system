{"ast":null,"code":"import { Plus } from '@element-plus/icons-vue';\nimport axios from 'axios';\nimport WangEditor from '../components/WangEditor.vue';\nexport default {\n  components: {\n    Plus,\n    WangEditor\n  },\n  data() {\n    return {\n      articles: [],\n      categories: [],\n      tags: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: null,\n        title: '',\n        categoryId: null,\n        tagIds: [],\n        coverImage: '',\n        content: ''\n      }\n    };\n  },\n  async mounted() {\n    await this.loadArticles();\n    await this.loadCategories();\n    await this.loadTags();\n  },\n  methods: {\n    async loadArticles() {\n      try {\n        const response = await axios.get('/api/v1/articles', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        });\n        this.articles = response.data.data.map(article => ({\n          ...article,\n          categoryName: article.category?.name || '未分类',\n          authorName: article.author?.nickname || '未知',\n          statusText: article.status === 1 ? '已发布' : '草稿'\n        }));\n        this.total = response.data.total;\n      } catch (error) {\n        console.error('加载文章失败:', error);\n        this.$message.error('加载文章失败');\n      }\n    },\n    async loadCategories() {\n      try {\n        const response = await axios.get('/api/v1/categories');\n        this.categories = response.data.data;\n      } catch (error) {\n        console.error('加载栏目失败:', error);\n        this.$message.error('加载栏目失败');\n      }\n    },\n    async loadTags() {\n      try {\n        const response = await axios.get('/api/v1/tags');\n        this.tags = response.data.data;\n      } catch (error) {\n        console.error('加载标签失败:', error);\n        this.$message.error('加载标签失败');\n      }\n    },\n    handleCreate() {\n      this.dialogTitle = '新建文章';\n      this.form = {\n        id: null,\n        title: '',\n        categoryId: null,\n        tagIds: [],\n        coverImage: '',\n        content: ''\n      };\n      this.dialogVisible = true;\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑文章';\n      this.form = {\n        ...row\n      };\n      this.dialogVisible = true;\n    },\n    handleDelete(row) {\n      this.$confirm('确定要删除这篇文章吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          await axios.delete(`/api/v1/articles/${row.id}`);\n          this.$message.success('删除成功');\n          this.loadArticles();\n        } catch (error) {\n          console.error('删除文章失败:', error);\n          this.$message.error('删除文章失败');\n        }\n      }).catch(() => {});\n    },\n    handleAvatarSuccess(response, uploadFile) {\n      if (response.success) {\n        this.form.coverImage = response.data.url;\n      } else {\n        this.$message.error('封面图片上传失败');\n      }\n    },\n    async handleSave() {\n      try {\n        if (this.form.id) {\n          // 更新文章\n          await axios.put(`/api/v1/articles/${this.form.id}`, this.form);\n          this.$message.success('文章更新成功');\n        } else {\n          // 创建文章\n          await axios.post('/api/v1/articles', this.form);\n          this.$message.success('文章创建成功');\n        }\n        this.dialogVisible = false;\n        this.loadArticles();\n      } catch (error) {\n        console.error('保存文章失败:', error);\n        this.$message.error('保存文章失败');\n      }\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadArticles();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadArticles();\n    }\n  }\n};","map":{"version":3,"names":["Plus","axios","WangEditor","components","data","articles","categories","tags","total","currentPage","pageSize","dialogVisible","dialogTitle","form","id","title","categoryId","tagIds","coverImage","content","mounted","loadArticles","loadCategories","loadTags","methods","response","get","params","page","size","map","article","categoryName","category","name","authorName","author","nickname","statusText","status","error","console","$message","handleCreate","handleEdit","row","handleDelete","$confirm","confirmButtonText","cancelButtonText","type","then","delete","success","catch","handleAvatarSuccess","uploadFile","url","handleSave","put","post","handleSizeChange","val","handleCurrentChange"],"sources":["/app/portal-system/portal-admin/src/views/ArticleList.vue"],"sourcesContent":["<template>\n  <div class=\"article-list\">\n    <el-card class=\"box-card\">\n      <template #header>\n        <div class=\"card-header\">\n          <span>文章管理</span>\n          <el-button class=\"button\" type=\"primary\" @click=\"handleCreate\">新建文章</el-button>\n        </div>\n      </template>\n      \n      <el-table :data=\"articles\" style=\"width: 100%\">\n        <el-table-column prop=\"title\" label=\"标题\" width=\"200\" />\n        <el-table-column prop=\"categoryName\" label=\"栏目\" width=\"120\" />\n        <el-table-column prop=\"authorName\" label=\"作者\" width=\"120\" />\n        <el-table-column prop=\"viewCount\" label=\"浏览量\" width=\"80\" />\n        <el-table-column prop=\"statusText\" label=\"状态\" width=\"100\" />\n        <el-table-column prop=\"createdAt\" label=\"创建时间\" width=\"180\" />\n        <el-table-column label=\"操作\" width=\"180\">\n          <template #default=\"scope\">\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-button size=\"small\" type=\"danger\" @click=\"handleDelete(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      \n      <el-pagination\n        v-model:current-page=\"currentPage\"\n        v-model:page-size=\"pageSize\"\n        :total=\"total\"\n        layout=\"total, prev, pager, next\"\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n      />\n    </el-card>\n    \n    <!-- 编辑对话框 -->\n    <el-dialog v-model=\"dialogVisible\" :title=\"dialogTitle\" width=\"80%\" destroy-on-close>\n      <el-form :model=\"form\" label-width=\"80px\">\n        <el-form-item label=\"标题\">\n          <el-input v-model=\"form.title\" />\n        </el-form-item>\n        <el-form-item label=\"栏目\">\n          <el-select v-model=\"form.categoryId\" placeholder=\"请选择栏目\">\n            <el-option\n              v-for=\"category in categories\"\n              :key=\"category.id\"\n              :label=\"category.name\"\n              :value=\"category.id\"\n            />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"标签\">\n          <el-select v-model=\"form.tagIds\" multiple placeholder=\"请选择标签\">\n            <el-option\n              v-for=\"tag in tags\"\n              :key=\"tag.id\"\n              :label=\"tag.name\"\n              :value=\"tag.id\"\n            />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"封面图片\">\n          <el-upload\n            class=\"avatar-uploader\"\n            action=\"/api/v1/files/upload\"\n            :show-file-list=\"false\"\n            :on-success=\"handleAvatarSuccess\"\n            :headers=\"{ 'X-Requested-With': 'XMLHttpRequest' }\"\n          >\n            <img v-if=\"form.coverImage\" :src=\"form.coverImage\" class=\"avatar\" />\n            <el-icon v-else class=\"avatar-uploader-icon\"><Plus /></el-icon>\n          </el-upload>\n        </el-form-item>\n        <el-form-item label=\"内容\">\n          <WangEditor v-model=\"form.content\" />\n        </el-form-item>\n      </el-form>\n      <template #footer>\n        <span class=\"dialog-footer\">\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"handleSave\">保存</el-button>\n        </span>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { Plus } from '@element-plus/icons-vue'\nimport axios from 'axios'\nimport WangEditor from '../components/WangEditor.vue'\n\nexport default {\n  components: {\n    Plus,\n    WangEditor\n  },\n  data() {\n    return {\n      articles: [],\n      categories: [],\n      tags: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: null,\n        title: '',\n        categoryId: null,\n        tagIds: [],\n        coverImage: '',\n        content: ''\n      }\n    }\n  },\n  async mounted() {\n    await this.loadArticles()\n    await this.loadCategories()\n    await this.loadTags()\n  },\n  methods: {\n    async loadArticles() {\n      try {\n        const response = await axios.get('/api/v1/articles', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        })\n        this.articles = response.data.data.map(article => ({\n          ...article,\n          categoryName: article.category?.name || '未分类',\n          authorName: article.author?.nickname || '未知',\n          statusText: article.status === 1 ? '已发布' : '草稿'\n        }))\n        this.total = response.data.total\n      } catch (error) {\n        console.error('加载文章失败:', error)\n        this.$message.error('加载文章失败')\n      }\n    },\n    async loadCategories() {\n      try {\n        const response = await axios.get('/api/v1/categories')\n        this.categories = response.data.data\n      } catch (error) {\n        console.error('加载栏目失败:', error)\n        this.$message.error('加载栏目失败')\n      }\n    },\n    async loadTags() {\n      try {\n        const response = await axios.get('/api/v1/tags')\n        this.tags = response.data.data\n      } catch (error) {\n        console.error('加载标签失败:', error)\n        this.$message.error('加载标签失败')\n      }\n    },\n    handleCreate() {\n      this.dialogTitle = '新建文章'\n      this.form = {\n        id: null,\n        title: '',\n        categoryId: null,\n        tagIds: [],\n        coverImage: '',\n        content: ''\n      }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑文章'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleDelete(row) {\n      this.$confirm('确定要删除这篇文章吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          await axios.delete(`/api/v1/articles/${row.id}`)\n          this.$message.success('删除成功')\n          this.loadArticles()\n        } catch (error) {\n          console.error('删除文章失败:', error)\n          this.$message.error('删除文章失败')\n        }\n      }).catch(() => {})\n    },\n    handleAvatarSuccess(response, uploadFile) {\n      if (response.success) {\n        this.form.coverImage = response.data.url\n      } else {\n        this.$message.error('封面图片上传失败')\n      }\n    },\n    async handleSave() {\n      try {\n        if (this.form.id) {\n          // 更新文章\n          await axios.put(`/api/v1/articles/${this.form.id}`, this.form)\n          this.$message.success('文章更新成功')\n        } else {\n          // 创建文章\n          await axios.post('/api/v1/articles', this.form)\n          this.$message.success('文章创建成功')\n        }\n        this.dialogVisible = false\n        this.loadArticles()\n      } catch (error) {\n        console.error('保存文章失败:', error)\n        this.$message.error('保存文章失败')\n      }\n    },\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadArticles()\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadArticles()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.avatar-uploader .el-upload {\n  border: 1px dashed var(--el-border-color);\n  border-radius: 6px;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n  transition: var(--el-transition-duration-fast);\n}\n.avatar-uploader .el-upload:hover {\n  border-color: var(--el-color-primary);\n}\n.el-icon.avatar-uploader-icon {\n  font-size: 28px;\n  color: #8c939d;\n  width: 178px;\n  height: 178px;\n  text-align: center;\n}\n.avatar {\n  width: 178px;\n  height: 178px;\n  display: block;\n}\n</style>"],"mappings":"AAwFA,SAASA,IAAG,QAAS,yBAAwB;AAC7C,OAAOC,KAAI,MAAO,OAAM;AACxB,OAAOC,UAAS,MAAO,8BAA6B;AAEpD,eAAe;EACbC,UAAU,EAAE;IACVH,IAAI;IACJE;EACF,CAAC;EACDE,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,IAAI,EAAE,EAAE;MACRC,KAAK,EAAE,CAAC;MACRC,WAAW,EAAE,CAAC;MACdC,QAAQ,EAAE,EAAE;MACZC,aAAa,EAAE,KAAK;MACpBC,WAAW,EAAE,EAAE;MACfC,IAAI,EAAE;QACJC,EAAE,EAAE,IAAI;QACRC,KAAK,EAAE,EAAE;QACTC,UAAU,EAAE,IAAI;QAChBC,MAAM,EAAE,EAAE;QACVC,UAAU,EAAE,EAAE;QACdC,OAAO,EAAE;MACX;IACF;EACF,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAM,IAAI,CAACC,YAAY,CAAC;IACxB,MAAM,IAAI,CAACC,cAAc,CAAC;IAC1B,MAAM,IAAI,CAACC,QAAQ,CAAC;EACtB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMH,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF,MAAMI,QAAO,GAAI,MAAMxB,KAAK,CAACyB,GAAG,CAAC,kBAAkB,EAAE;UACnDC,MAAM,EAAE;YACNC,IAAI,EAAE,IAAI,CAACnB,WAAW;YACtBoB,IAAI,EAAE,IAAI,CAACnB;UACb;QACF,CAAC;QACD,IAAI,CAACL,QAAO,GAAIoB,QAAQ,CAACrB,IAAI,CAACA,IAAI,CAAC0B,GAAG,CAACC,OAAM,KAAM;UACjD,GAAGA,OAAO;UACVC,YAAY,EAAED,OAAO,CAACE,QAAQ,EAAEC,IAAG,IAAK,KAAK;UAC7CC,UAAU,EAAEJ,OAAO,CAACK,MAAM,EAAEC,QAAO,IAAK,IAAI;UAC5CC,UAAU,EAAEP,OAAO,CAACQ,MAAK,KAAM,IAAI,KAAI,GAAI;QAC7C,CAAC,CAAC;QACF,IAAI,CAAC/B,KAAI,GAAIiB,QAAQ,CAACrB,IAAI,CAACI,KAAI;MACjC,EAAE,OAAOgC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,SAAS,EAAEA,KAAK;QAC9B,IAAI,CAACE,QAAQ,CAACF,KAAK,CAAC,QAAQ;MAC9B;IACF,CAAC;IACD,MAAMlB,cAAcA,CAAA,EAAG;MACrB,IAAI;QACF,MAAMG,QAAO,GAAI,MAAMxB,KAAK,CAACyB,GAAG,CAAC,oBAAoB;QACrD,IAAI,CAACpB,UAAS,GAAImB,QAAQ,CAACrB,IAAI,CAACA,IAAG;MACrC,EAAE,OAAOoC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,SAAS,EAAEA,KAAK;QAC9B,IAAI,CAACE,QAAQ,CAACF,KAAK,CAAC,QAAQ;MAC9B;IACF,CAAC;IACD,M