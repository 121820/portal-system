Index = ref(route.path)\n    \n    const handleSelect = (key) => {\n      router.push(key)\n    }\n    \n    // 监听路由变化更新激活状态\n    onMounted(() => {\n      activeIndex.value = route.path\n    })\n    \n    return {\n      activeIndex,\n      handleSelect\n    }\n  }\n}\n</script>\n\n<style scoped>\n.sidebar-menu {\n  height: 100%;\n  border-right: none;\n}\n</style>"],"mappings":";AA2BA,SAASA,GAAG,EAAEC,SAAQ,QAAS,KAAI;AACnC,SAASC,SAAS,EAAEC,QAAO,QAAS,YAAW;AAC/C,SAASC,QAAQ,EAAEC,MAAM,EAAEC,QAAQ,EAAEC,IAAG,QAAS,yBAAwB;AAEzE,eAAe;EACbC,UAAU,EAAE;IACVJ,QAAQ;IACRC,MAAM;IACNC,QAAQ;IACRC;EACF,CAAC;EACDE,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIR,SAAS,CAAC;IACzB,MAAMS,KAAI,GAAIR,QAAQ,CAAC;IACvB,MAAMS,WAAU,GAAIZ,GAAG,CAACW,KAAK,CAACE,IAAI;IAElC,MAAMC,YAAW,GAAKC,GAAG,IAAK;MAC5BL,MAAM,CAACM,IAAI,CAACD,GAAG;IACjB;;IAEA;IACAd,SAAS,CAAC,MAAM;MACdW,WAAW,CAACK,KAAI,GAAIN,KAAK,CAACE,IAAG;IAC/B,CAAC;IAED,OAAO;MACLD,WAAW;MACXE;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}