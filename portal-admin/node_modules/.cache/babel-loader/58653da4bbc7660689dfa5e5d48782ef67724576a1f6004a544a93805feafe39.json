{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { useRouter, useRoute } from 'vue-router';\nimport { ElMessage, ElMessageBox } from 'element-plus';\nimport axios from 'axios';\nexport default {\n  data() {\n    return {\n      article: {\n        id: null,\n        title: '',\n        categoryName: '',\n        authorName: '',\n        viewCount: 0,\n        statusText: '',\n        createdAt: '',\n        tags: [],\n        content: ''\n      },\n      previewVisible: false\n    };\n  },\n  async mounted() {\n    await this.loadArticle();\n  },\n  methods: {\n    async loadArticle() {\n      try {\n        const route = useRoute();\n        const articleId = route.params.id;\n        const response = await axios.get(`/api/v1/articles/${articleId}`);\n        const articleData = response.data.data;\n        this.article = {\n          ...articleData,\n          categoryName: articleData.category?.name || '未分类',\n          authorName: articleData.author?.nickname || '未知',\n          statusText: articleData.status === 1 ? '已发布' : '草稿',\n          tags: articleData.tags || []\n        };\n      } catch (error) {\n        console.error('加载文章详情失败:', error);\n        ElMessage.error('加载文章详情失败');\n        this.handleBack();\n      }\n    },\n    handleBack() {\n      const router = useRouter();\n      router.push('/articles');\n    },\n    handleEdit() {\n      const router = useRouter();\n      router.push(`/articles/edit/${this.article.id}`);\n    },\n    handleDelete() {\n      ElMessageBox.confirm('确定要删除这篇文章吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          await axios.delete(`/api/v1/articles/${this.article.id}`);\n          ElMessage.success('删除成功');\n          this.handleBack();\n        } catch (error) {\n          console.error('删除文章失败:', error);\n          ElMessage.error('删除文章失败');\n        }\n      }).catch(() => {});\n    },\n    handlePreview() {\n      this.previewVisible = true;\n    },\n    formatDate(dateString) {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return date.toLocaleString('zh-CN');\n    }\n  }\n};","map":{"version":3,"names":["useRouter","useRoute","ElMessage","ElMessageBox","axios","data","article","id","title","categoryName","authorName","viewCount","statusText","createdAt","tags","content","previewVisible","mounted","loadArticle","methods","route","articleId","params","response","get","articleData","category","name","author","nickname","status","error","console","handleBack","router","push","handleEdit","handleDelete","confirm","confirmButtonText","cancelButtonText","type","then","delete","success","catch","handlePreview","formatDate","dateString","date","Date","toLocaleString"],"sources":["/app/portal-system/portal-admin/src/views/ArticleDetail.vue"],"sourcesContent":["<template>\n  <div class=\"article-detail\">\n    <el-card class=\"box-card\">\n      <template #header>\n        <div class=\"card-header\">\n          <span>{{ article.title }}</span>\n          <el-button class=\"button\" @click=\"handleBack\">返回列表</el-button>\n        </div>\n      </template>\n      \n      <div class=\"article-meta\">\n        <el-tag type=\"info\">{{ article.categoryName }}</el-tag>\n        <el-tag v-for=\"tag in article.tags\" :key=\"tag.id\" style=\"margin-left: 8px;\">{{ tag.name }}</el-tag>\n        <div class=\"meta-info\">\n          <span>作者: {{ article.authorName }}</span>\n          <span>发布时间: {{ formatDate(article.createdAt) }}</span>\n          <span>浏览量: {{ article.viewCount }}</span>\n          <span>状态: {{ article.statusText }}</span>\n        </div>\n      </div>\n      \n      <div class=\"article-content\" v-html=\"article.content\"></div>\n      \n      <div class=\"article-actions\" style=\"margin-top: 20px;\">\n        <el-button @click=\"handleEdit\">编辑</el-button>\n        <el-button type=\"danger\" @click=\"handleDelete\">删除</el-button>\n        <el-button @click=\"handlePreview\">预览</el-button>\n      </div>\n    </el-card>\n    \n    <!-- 预览对话框 -->\n    <el-dialog v-model=\"previewVisible\" title=\"文章预览\" width=\"80%\" destroy-on-close>\n      <div class=\"preview-content\" v-html=\"article.content\"></div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { useRouter, useRoute } from 'vue-router'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport axios from 'axios'\n\nexport default {\n  data() {\n    return {\n      article: {\n        id: null,\n        title: '',\n        categoryName: '',\n        authorName: '',\n        viewCount: 0,\n        statusText: '',\n        createdAt: '',\n        tags: [],\n        content: ''\n      },\n      previewVisible: false\n    }\n  },\n  async mounted() {\n    await this.loadArticle()\n  },\n  methods: {\n    async loadArticle() {\n      try {\n        const route = useRoute()\n        const articleId = route.params.id\n        \n        const response = await axios.get(`/api/v1/articles/${articleId}`)\n        const articleData = response.data.data\n        \n        this.article = {\n          ...articleData,\n          categoryName: articleData.category?.name || '未分类',\n          authorName: articleData.author?.nickname || '未知',\n          statusText: articleData.status === 1 ? '已发布' : '草稿',\n          tags: articleData.tags || []\n        }\n      } catch (error) {\n        console.error('加载文章详情失败:', error)\n        ElMessage.error('加载文章详情失败')\n        this.handleBack()\n      }\n    },\n    handleBack() {\n      const router = useRouter()\n      router.push('/articles')\n    },\n    handleEdit() {\n      const router = useRouter()\n      router.push(`/articles/edit/${this.article.id}`)\n    },\n    handleDelete() {\n      ElMessageBox.confirm('确定要删除这篇文章吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          await axios.delete(`/api/v1/articles/${this.article.id}`)\n          ElMessage.success('删除成功')\n          this.handleBack()\n        } catch (error) {\n          console.error('删除文章失败:', error)\n          ElMessage.error('删除文章失败')\n        }\n      }).catch(() => {})\n    },\n    handlePreview() {\n      this.previewVisible = true\n    },\n    formatDate(dateString) {\n      if (!dateString) return ''\n      const date = new Date(dateString)\n      return date.toLocaleString('zh-CN')\n    }\n  }\n}\n</script>\n\n<style scoped>\n.article-meta {\n  margin-bottom: 20px;\n}\n.meta-info {\n  margin-top: 10px;\n  font-size: 14px;\n  color: #666;\n}\n.meta-info span {\n  margin-right: 20px;\n}\n.article-content {\n  line-height: 1.6;\n  font-size: 16px;\n}\n.preview-content {\n  line-height: 1.6;\n  font-size: 16px;\n}\n</style>"],"mappings":";AAsCA,SAASA,SAAS,EAAEC,QAAO,QAAS,YAAW;AAC/C,SAASC,SAAS,EAAEC,YAAW,QAAS,cAAa;AACrD,OAAOC,KAAI,MAAO,OAAM;AAExB,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE;QACPC,EAAE,EAAE,IAAI;QACRC,KAAK,EAAE,EAAE;QACTC,YAAY,EAAE,EAAE;QAChBC,UAAU,EAAE,EAAE;QACdC,SAAS,EAAE,CAAC;QACZC,UAAU,EAAE,EAAE;QACdC,SAAS,EAAE,EAAE;QACbC,IAAI,EAAE,EAAE;QACRC,OAAO,EAAE;MACX,CAAC;MACDC,cAAc,EAAE;IAClB;EACF,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAM,IAAI,CAACC,WAAW,CAAC;EACzB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,WAAWA,CAAA,EAAG;MAClB,IAAI;QACF,MAAME,KAAI,GAAInB,QAAQ,CAAC;QACvB,MAAMoB,SAAQ,GAAID,KAAK,CAACE,MAAM,CAACf,EAAC;QAEhC,MAAMgB,QAAO,GAAI,MAAMnB,KAAK,CAACoB,GAAG,CAAC,oBAAoBH,SAAS,EAAE;QAChE,MAAMI,WAAU,GAAIF,QAAQ,CAAClB,IAAI,CAACA,IAAG;QAErC,IAAI,CAACC,OAAM,GAAI;UACb,GAAGmB,WAAW;UACdhB,YAAY,EAAEgB,WAAW,CAACC,QAAQ,EAAEC,IAAG,IAAK,KAAK;UACjDjB,UAAU,EAAEe,WAAW,CAACG,MAAM,EAAEC,QAAO,IAAK,IAAI;UAChDjB,UAAU,EAAEa,WAAW,CAACK,MAAK,KAAM,IAAI,KAAI,GAAI,IAAI;UACnDhB,IAAI,EAAEW,WAAW,CAACX,IAAG,IAAK;QAC5B;MACF,EAAE,OAAOiB,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;QAChC7B,SAAS,CAAC6B,KAAK,CAAC,UAAU;QAC1B,IAAI,CAACE,UAAU,CAAC;MAClB;IACF,CAAC;IACDA,UAAUA,CAAA,